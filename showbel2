local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Lấy Data
local Data = LocalPlayer:WaitForChild("Data", 10)
if not Data then
    warn("Không tìm thấy Data!")
    return
end

local BeliValue = Data:WaitForChild("Beli", 10)
if not BeliValue then
    warn("Không tìm thấy Beli!")
    return
end

-- Tạo GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "BeliGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local BeliLabel = Instance.new("TextLabel")
BeliLabel.Size = UDim2.new(0, 230, 0, 45)

-- góc trên phải màn hình
BeliLabel.AnchorPoint = Vector2.new(1, 0)
BeliLabel.Position = UDim2.new(1, -20, 0, 20)

BeliLabel.BackgroundTransparency = 0.2
BeliLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
BeliLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
BeliLabel.Font = Enum.Font.GothamBold
BeliLabel.TextScaled = true
BeliLabel.BorderSizePixel = 0
BeliLabel.Text = "Beli: 0"
BeliLabel.Parent = ScreenGui

-- Format số
local function formatNumber(num)
    local formatted = tostring(num)
    while true do
        local new, k = formatted:gsub("^(-?%d+)(%d%d%d)", "%1.%2")
        formatted = new
        if k == 0 then break end
    end
    return formatted
end

-- Update Beli
local function updateBeli()
    BeliLabel.Text = "Beli: " .. formatNumber(BeliValue.Value)
end

BeliValue:GetPropertyChangedSignal("Value"):Connect(updateBeli)
updateBeli()
